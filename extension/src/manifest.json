{
    "name": "__MSG_extensionName__",
    "description": "Enables Chromecast support for casting web apps (like Netflix or BBC iPlayer), HTML5 video and screen sharing.",
    "version": "0.4.0",
    "developer": {
        "name": "William Gwin (unoffical contributor)",
        "url": "https://github.com/gitxpresso/"
    },

    "browser_specific_settings": {
        "gecko": {
            "data_collection_permissions": {
                "required": [ 
                    "locationInfo"
                ],
                "optional": [
                    "technicalAndInteraction"
                ]
            },
            "id": "fx_cast-nightly@gitxpresso",
            "strict_min_version": "109.0",
            "update_url": "https://gitxpresso.github.io/fx_cast/updates.json"
        }
    },
    "action": {
        "theme_icons": [
            {
                "light": "icons/cast-default-light.svg",
                "dark": "icons/cast-default-dark.svg",
                "size": 32
            }
        ]
    },

    "background": {
        "scripts": ["background/background.js"]
    },

    "default_locale": "en",

    "icons": {
        "48": "icons/icon.svg",
        "96": "icons/icon.svg"
    },

    "manifest_version": 3,
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self';"
    },
    "options_ui": {
        "page": "ui/options/index.html"
    },
    "permissions": [
        "history",
        "menus",
        "menus.overrideContext",
        "nativeMessaging",
        "notifications",
        "scripting",
        "storage",
        "tabs",
        "webNavigation",
        "webRequest",
        "webRequestBlocking"
    ],
    "host_permissions": ["<all_urls>"],
    "web_accessible_resources": [
        {
            "resources": ["cast/content.js"],
            "matches": ["<all_urls>"]
        }
    ]
}
